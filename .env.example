# Copy to .env and adjust — only used in development
# On production (shared hosting) set these as Apache SetEnv or php.ini directives

APP_DEBUG=false

# Subfolder install: set to the path prefix WITHOUT trailing slash.
# Leave empty (or omit) for a root install (domain.com).
# Example: APP_BASE_PATH=/nanofin
APP_BASE_PATH=

# Optional: override paths
# DB_PATH=/absolute/path/to/nanofin.db
