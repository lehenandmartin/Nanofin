{
    "name": "nanofin/nanofin",
    "description": "Lightweight web interface for Jellyfin — browse and download without a Jellyfin account",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "php-di/php-di": "^7.1",
        "phpmailer/phpmailer": "^7.1",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.26"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nanofin\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
