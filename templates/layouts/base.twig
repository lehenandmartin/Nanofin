<!doctype html>
<html lang="{{ locale }}" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
    <title>{% block title %}{{ settings.site_title ?? 'Nanofin' }}{% endblock %}</title>

    <link rel="icon" type="image/svg+xml" href="{{ url('/favicon.svg') }}">
    <link rel="apple-touch-icon" href="{{ url('/apple-touch-icon.png') }}">

    {# Dynamic values read by app.js — avoids CSP-blocked inline scripts #}
    <meta name="app-base-path" content="{{ base_path }}">
    <meta name="csrf-token"    content="{{ csrf_token }}">

    {# Built assets — committed to repository #}
    <link rel="stylesheet" href="{{ url('/assets/app.css') }}">

    {% block head %}{% endblock %}
</head>
<body class="min-h-full flex flex-col" x-data>

{# ── Flash messages ──────────────────────────────────────────── #}
{% if flash_messages is defined and flash_messages %}
<div class="fixed top-4 right-4 z-50 space-y-2" x-data>
    {% for msg in flash_messages %}
    <div class="flex items-center gap-3 px-4 py-3 rounded-lg shadow-lg text-sm font-medium
                {% if msg.type == 'success' %}bg-green-600 text-white
                {% elseif msg.type == 'error' %}bg-red-600 text-white
                {% else %}bg-[var(--color-surface)] text-[var(--color-text)] border border-[var(--color-border)]{% endif %}"
         x-data="{ show: true }" x-show="show" x-transition
         x-init="setTimeout(() => show = false, 4000)">
        {{ msg.text }}
    </div>
    {% endfor %}
</div>
{% endif %}

{# ── Navigation ──────────────────────────────────────────────── #}
<header class="bg-[var(--color-surface)] border-b border-[var(--color-border)] sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">

        {# Logo / site title #}
        <a href="{{ url('/') }}" class="flex items-center gap-2 text-xl font-bold text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline">
            <svg class="w-6 h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 8a2 2 0 0 0 0-4 2 2 0 0 0-4 0 2 2 0 0 0-4 0 2 2 0 0 0-4 0 2 2 0 0 0 0 4"/>
                <path d="M10 22 9 8"/>
                <path d="m14 22 1-14"/>
                <path d="M20 8c.5 0 .9.4.8 1l-2.6 12c-.1.5-.7 1-1.2 1H7c-.6 0-1.1-.4-1.2-1L3.2 9c-.1-.6.3-1 .8-1Z"/>
            </svg>
            {{ settings.site_title ?? 'Nanofin' }}
        </a>

        {# Right side #}
        <div class="flex items-center gap-3">
            {% if auth_user %}
                {% if auth_user.role == 'admin' %}
                <a href="{{ url('/admin') }}" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)]">
                    {{ trans('nav.admin') }}
                </a>
                {% endif %}
                <a href="{{ url('/account') }}"
                   class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)]">
                    {{ auth_user.username }}
                </a>
                <form action="{{ url('/logout') }}" method="post" class="inline">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <button type="submit" class="btn-ghost text-sm py-1.5">
                        {{ trans('nav.logout') }}
                    </button>
                </form>
            {% else %}
                <a href="{{ url('/login') }}" class="btn-primary text-sm py-1.5">
                    {{ trans('nav.login') }}
                </a>
            {% endif %}
        </div>
    </div>
</header>

{# ── Main content ────────────────────────────────────────────── #}
<main class="flex-1">
    {% block content %}{% endblock %}
</main>

{# ── Footer ──────────────────────────────────────────────────── #}
<footer class="border-t border-[var(--color-border)] py-6 text-center text-xs text-[var(--color-muted)]">
    {% block footer %}
    {{ trans('footer.powered_by') }}
    <a href="{{ app_github_url }}" target="_blank" rel="noopener noreferrer"
       class="hover:text-[var(--color-text)] transition-colors">Nanofin</a>
    {{ app_version }}
    {% endblock %}
</footer>

{% block scripts %}{% endblock %}
<script src="{{ url('/assets/app.js') }}"></script>
</body>
</html>
