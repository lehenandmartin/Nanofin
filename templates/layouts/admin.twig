{% extends 'layouts/base.twig' %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row gap-8">

        {# ── Sidebar ─────────────────────────────────────────── #}
        <aside class="lg:w-52 flex-shrink-0">
            <nav class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl
                        overflow-hidden sticky top-24">

                <div class="px-4 py-3 border-b border-[var(--color-border)]">
                    <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)]">
                        {{ trans('admin.title') }}
                    </p>
                </div>

                {% set navItems = [
                    {href: url('/admin'),          icon: 'grid',    label: trans('admin.nav.dashboard')},
                    {href: url('/admin/settings'), icon: 'cog',     label: trans('admin.nav.settings')},
                    {href: url('/admin/users'),    icon: 'users',   label: trans('admin.nav.users')},
                    {href: url('/admin/logs'),     icon: 'list',    label: trans('admin.nav.logs')},
                ] %}

                <ul class="p-2 space-y-0.5">
                {% for item in navItems %}
                {% set active = (app.request.uri.path starts with item.href and
                                 (item.href != '/admin' or app.request.uri.path == '/admin')) %}
                <li>
                    <a href="{{ item.href }}"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors
                              {% if adminSection is defined and url(adminSection) == item.href %}
                                  bg-[var(--color-accent)]/15 text-[var(--color-accent)] font-medium
                              {% else %}
                                  text-[var(--color-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-alt)]
                              {% endif %}">
                        {% if item.icon == 'grid' %}
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                        </svg>
                        {% elseif item.icon == 'cog' %}
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        {% elseif item.icon == 'users' %}
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                        </svg>
                        {% else %}
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                        </svg>
                        {% endif %}
                        {{ item.label }}
                    </a>
                </li>
                {% endfor %}
                </ul>

                {# Revoke sessions button #}
                <div class="p-3 border-t border-[var(--color-border)]">
                    <form method="post" action="{{ url('/admin/sessions/revoke') }}"
                          x-data
                          @submit.prevent="if(confirm('{{ trans('admin.sessions.revoke_confirm')|e('js') }}')) $el.submit()">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <button type="submit"
                                class="w-full text-left flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm
                                       text-red-400 hover:bg-red-500/10 transition-colors">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                            </svg>
                            {{ trans('admin.sessions.revoke') }}
                        </button>
                    </form>
                </div>

            </nav>
        </aside>

        {# ── Main content ────────────────────────────────────── #}
        <div class="flex-1 min-w-0">
            {% block admin_content %}{% endblock %}
        </div>

    </div>
</div>
{% endblock %}
