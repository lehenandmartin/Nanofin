<!doctype html>
<html lang="{{ locale ?? 'en' }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block subject %}{{ siteName }}{% endblock %}</title>
<style>
  body { margin:0; padding:0; background:#0f1117; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; }
  .wrapper { width:100%; background:#0f1117; padding:40px 16px; }
  .card { max-width:520px; margin:0 auto; background:#1a1d27; border:1px solid #2c3150; border-radius:16px; overflow:hidden; }
  .header { background:#21253a; padding:28px 32px; border-bottom:1px solid #2c3150; }
  .header h1 { margin:0; font-size:20px; font-weight:800; color:#e4e6f0; letter-spacing:-.3px; }
  .body { padding:32px; color:#e4e6f0; font-size:15px; line-height:1.6; }
  .body p { margin:0 0 16px; }
  .body p:last-child { margin-bottom:0; }
  .btn { display:inline-block; margin:8px 0; padding:12px 24px; background:#6c63ff; color:#fff !important;
         text-decoration:none; border-radius:8px; font-weight:600; font-size:15px; }
  .meta { background:#21253a; border-top:1px solid #2c3150; padding:16px 32px; }
  .meta table { width:100%; border-collapse:collapse; }
  .meta td { padding:5px 0; font-size:13px; color:#8b8fa8; vertical-align:top; }
  .meta td:first-child { width:40%; font-weight:600; color:#e4e6f0; }
  .footer { max-width:520px; margin:16px auto 0; text-align:center; font-size:12px; color:#8b8fa8; }
  .code { font-family:monospace; background:#21253a; border:1px solid #2c3150; border-radius:6px;
          padding:10px 14px; font-size:14px; color:#6c63ff; display:inline-block; margin:4px 0; }
</style>
</head>
<body>
<div class="wrapper">
  <div class="card">
    <div class="header">
      <h1>{{ siteName }}</h1>
    </div>
    <div class="body">
      {% block body %}{% endblock %}
    </div>
    {% block meta %}{% endblock %}
  </div>
  <div class="footer">
    {{ trans('email.footer', {'site': siteName}) }}
  </div>
</div>
</body>
</html>
