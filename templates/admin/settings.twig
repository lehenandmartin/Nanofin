{% extends 'layouts/admin.twig' %}

{% block title %}{{ trans('admin.settings.title') }} — {{ trans('admin.title') }}{% endblock %}

{% block admin_content %}

<h1 class="text-2xl font-black text-[var(--color-text)] mb-6">
    {{ trans('admin.settings.title') }}
</h1>

<form method="post" action="{{ url('/admin/settings') }}" x-data="{ loading: false }" @submit="loading = true">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

    <div class="space-y-6">

        {# ── Jellyfin ───────────────────────────────────────── #}
        <section class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-4">
                {{ trans('admin.settings.jellyfin') }}
            </h2>

            {# Reusable status-check icon macros #}
            {% macro ok_badge() %}
                <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                          d="M5 13l4 4L19 7"/>
                </svg>
            {% endmacro %}
            {% macro err_badge() %}
                <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                          d="M6 18L18 6M6 6l12 12"/>
                </svg>
            {% endmacro %}

            <div class="grid sm:grid-cols-2 gap-4">
                <div>
                    <label class="form-label flex items-center gap-1.5">
                        {{ trans('admin.settings.jellyfin_url') }}
                        {% if serverName %}
                            {{ _self.ok_badge() }}
                            <span class="text-green-400 font-normal normal-case tracking-normal">{{ serverName }}</span>
                        {% endif %}
                    </label>
                    <input type="url" name="jellyfin_url" class="form-input"
                           value="{{ s.jellyfin_url ?? '' }}"
                           placeholder="http://192.168.1.10:8096">
                </div>
                <div>
                    <label class="form-label flex items-center gap-1.5">
                        {{ trans('admin.settings.jellyfin_api_key') }}
                        {% if apiKeyOk %}{{ _self.ok_badge() }}{% endif %}
                    </label>
                    {% if s.jellyfin_api_key ?? '' %}
                    {# Key is set: masked display with a Replace toggle #}
                    <div x-data="{ replacing: false }">
                        <template x-if="!replacing">
                            <div class="flex items-center gap-2">
                                <input type="hidden" name="jellyfin_api_key" value="__KEEP__">
                                <span class="form-input font-mono text-[var(--color-muted)] flex-1
                                             select-none tracking-widest cursor-default">
                                    ••••••••••••••••
                                </span>
                                <button type="button" @click="replacing = true"
                                        class="btn-ghost text-sm shrink-0">
                                    {{ trans('admin.settings.api_key_replace') }}
                                </button>
                            </div>
                        </template>
                        <template x-if="replacing">
                            <div class="flex items-center gap-2">
                                <input type="text" name="jellyfin_api_key"
                                       class="form-input font-mono flex-1"
                                       autocomplete="off" spellcheck="false"
                                       placeholder="{{ trans('admin.settings.api_key_new_placeholder') }}"
                                       x-init="$el.focus()">
                                <button type="button" @click="replacing = false"
                                        class="btn-ghost text-sm shrink-0">
                                    {{ trans('admin.settings.api_key_cancel') }}
                                </button>
                            </div>
                        </template>
                    </div>
                    {% else %}
                    {# Key not set: plain input #}
                    <input type="text" name="jellyfin_api_key" class="form-input font-mono"
                           autocomplete="off" spellcheck="false"
                           placeholder="{{ trans('admin.settings.api_key_new_placeholder') }}">
                    {% endif %}
                </div>
            </div>
        </section>

        {# ── Site ───────────────────────────────────────────── #}
        <section class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-4">
                {{ trans('admin.settings.site') }}
            </h2>

            <div class="grid sm:grid-cols-2 gap-4">
                <div>
                    <label class="form-label">{{ trans('admin.settings.site_title') }}</label>
                    <input type="text" name="site_title" class="form-input"
                           value="{{ s.site_title ?? 'Nanofin' }}">
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.locale') }}</label>
                    <select name="default_locale" class="form-input">
                        {% for locale in locales %}
                        <option value="{{ locale }}"
                                {% if (s.default_locale ?? 'en') == locale %}selected{% endif %}>
                            {{ locale|upper }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.default_sort') }}</label>
                    <select name="default_sort" class="form-input">
                        {% for key, label in {
                            added:  trans('library.sort.added'),
                            title:  trans('library.sort.title'),
                            year:   trans('library.sort.year'),
                            rating: trans('library.sort.rating')
                        } %}
                        <option value="{{ key }}"
                                {% if (s.default_sort ?? 'added') == key %}selected{% endif %}>
                            {{ label }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.grid_rows') }}</label>
                    <input type="number" name="grid_rows" class="form-input"
                           value="{{ s.grid_rows ?? 4 }}" min="1" max="20" step="1">
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.timezone') }}</label>
                    <select name="timezone" class="form-input">
                        {% for group, tzList in timezones %}
                        <optgroup label="{{ group }}">
                            {% for tz in tzList %}
                            <option value="{{ tz }}"
                                    {% if (s.timezone ?? 'UTC') == tz %}selected{% endif %}>
                                {{ tz|replace({(group ~ '/'): ''}) }}
                            </option>
                            {% endfor %}
                        </optgroup>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.poster_cache_days') }}</label>
                    <input type="number" name="poster_cache_days" class="form-input"
                           value="{{ s.poster_cache_days ?? 7 }}" min="1" max="365">
                </div>
                <div class="sm:col-span-2">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <input type="checkbox" name="public_mode" value="1"
                               {% if (s.public_mode ?? '0') == '1' %}checked{% endif %}
                               class="w-4 h-4 rounded accent-[var(--color-accent)]">
                        <span class="text-sm text-[var(--color-text)]">
                            {{ trans('admin.settings.public_mode') }}
                        </span>
                    </label>
                </div>
                <div class="sm:col-span-2">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <input type="checkbox" name="allow_password_reset" value="1"
                               {% if (s.allow_password_reset ?? '0') == '1' %}checked{% endif %}
                               class="w-4 h-4 rounded accent-[var(--color-accent)]">
                        <span class="text-sm text-[var(--color-text)]">
                            {{ trans('admin.settings.allow_password_reset') }}
                        </span>
                    </label>
                    <p class="text-xs text-[var(--color-muted)] mt-1 ml-7">
                        {{ trans('admin.settings.allow_password_reset_hint') }}
                    </p>
                </div>
                <div class="sm:col-span-2">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <input type="checkbox" name="allow_magic_link" value="1"
                               {% if (s.allow_magic_link ?? '0') == '1' %}checked{% endif %}
                               class="w-4 h-4 rounded accent-[var(--color-accent)]">
                        <span class="text-sm text-[var(--color-text)]">
                            {{ trans('admin.settings.allow_magic_link') }}
                        </span>
                    </label>
                    <p class="text-xs text-[var(--color-muted)] mt-1 ml-7">
                        {{ trans('admin.settings.allow_magic_link_hint') }}
                    </p>
                </div>
            </div>
        </section>

        {# ── SMTP ───────────────────────────────────────────── #}
        <section class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-4">
                {{ trans('admin.settings.smtp') }}
            </h2>

            <div class="grid sm:grid-cols-2 gap-4">
                <div>
                    <label class="form-label flex items-center gap-1.5">
                        {{ trans('admin.settings.smtp_host') }}
                        {% if smtpOk %}
                            {{ _self.ok_badge() }}
                        {% elseif smtpHostError %}
                            {{ _self.err_badge() }}
                        {% endif %}
                    </label>
                    <input type="text" name="smtp_host" class="form-input"
                           value="{{ s.smtp_host ?? '' }}" placeholder="smtp.example.com">
                    {% if smtpHostError %}
                    <p class="text-xs text-red-400 mt-1">{{ smtpHostError }}</p>
                    {% endif %}
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.smtp_port') }}</label>
                    <input type="number" name="smtp_port" class="form-input"
                           value="{{ s.smtp_port ?? 587 }}" min="1" max="65535">
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.smtp_user') }}</label>
                    <input type="text" name="smtp_user" class="form-input"
                           value="{{ s.smtp_user ?? '' }}" autocomplete="off">
                </div>
                <div>
                    <label class="form-label flex items-center gap-1.5">
                        {{ trans('admin.settings.smtp_password') }}
                        {% if smtpAuthError %}{{ _self.err_badge() }}{% endif %}
                    </label>
                    {% if s.smtp_password ?? '' %}
                    {# Password is set: masked display with a Replace toggle #}
                    <div x-data="{ replacing: false }">
                        <template x-if="!replacing">
                            <div class="flex items-center gap-2">
                                <input type="hidden" name="smtp_password" value="__KEEP__">
                                <span class="form-input font-mono text-[var(--color-muted)] flex-1
                                             select-none tracking-widest cursor-default">
                                    ••••••••••••••••
                                </span>
                                <button type="button" @click="replacing = true"
                                        class="btn-ghost text-sm shrink-0">
                                    {{ trans('admin.settings.api_key_replace') }}
                                </button>
                            </div>
                        </template>
                        <template x-if="replacing">
                            <div class="flex items-center gap-2">
                                <input type="password" name="smtp_password"
                                       class="form-input flex-1"
                                       autocomplete="new-password"
                                       x-init="$el.focus()">
                                <button type="button" @click="replacing = false"
                                        class="btn-ghost text-sm shrink-0">
                                    {{ trans('admin.settings.api_key_cancel') }}
                                </button>
                            </div>
                        </template>
                    </div>
                    {% else %}
                    {# Password not set: plain input #}
                    <input type="password" name="smtp_password" class="form-input"
                           autocomplete="new-password">
                    {% endif %}
                    {% if smtpAuthError %}
                    <p class="text-xs text-red-400 mt-1">{{ smtpAuthError }}</p>
                    {% endif %}
                </div>
                <div>
                    <label class="form-label">{{ trans('admin.settings.smtp_from') }}</label>
                    <input type="email" name="smtp_from" class="form-input"
                           value="{{ s.smtp_from ?? '' }}" placeholder="noreply@example.com">
                </div>

            </div>
        </section>

        {# ── Submit ─────────────────────────────────────────── #}
        <div class="flex justify-end">
            <button type="submit" class="btn-primary" :disabled="loading">
                <svg x-show="loading" x-cloak class="animate-spin w-4 h-4"
                     xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
                </svg>
                {{ trans('admin.settings.save') }}
            </button>
        </div>

    </div>
</form>

{# ── Test email (separate form — must not be nested in settings form) ── #}
<section class="mt-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6"
         x-data="{ sending: false }">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-1">
        {{ trans('admin.settings.test_email.title') }}
    </h2>
    <p class="text-xs text-[var(--color-muted)] mb-4">
        {{ trans('admin.settings.test_email.notice') }}
    </p>

    <form method="post" action="{{ url('/admin/settings/test-email') }}"
          @submit="sending = true" class="flex gap-3 flex-wrap">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <input type="email" name="test_email_to" required
               placeholder="{{ trans('admin.settings.test_email.to') }}"
               class="form-input flex-1 min-w-48">

        <button type="submit" class="btn-ghost flex items-center gap-2" :disabled="sending">
            <svg x-show="sending" x-cloak class="animate-spin w-4 h-4"
                 xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
            </svg>
            <svg x-show="!sending" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            {{ trans('admin.settings.test_email.send') }}
        </button>
    </form>
</section>

{% endblock %}
